{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile & Run (input.txt → output.txt)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "cd /d \"${workspaceFolder}\" && javac \"${relativeFile}\" && java ${relativeFileDirname}.${fileBasenameNoExtension} < input.txt > output.txt"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Compile & Run (Terminal Input)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "cd /d \"${workspaceFolder}\" && javac \"${relativeFile}\" && java ${relativeFileDirname}.${fileBasenameNoExtension}"
      ]
    }
  ]
}